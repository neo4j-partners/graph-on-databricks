# Local-demo .env for the Finance Genie dbxcarta consumer.
#
# Copy this file to `.env` in this same directory before running the local
# demo. The demo loads `.env` anchored to this directory and is the single
# source of truth for the local demo.
#
# The dbxcarta CLI (--check-ready, --upload-questions, ingest) is a separate
# workflow whose per-integration config is the committed, secret-free
# ./dbxcarta-overlay.env. Edit that file, not this one, to change a CLI run.

# --- Operator credentials (fill these in) ---------------------------------

DATABRICKS_PROFILE=aws-partner-rk
DATABRICKS_WAREHOUSE_ID=
DBXCARTA_CHAT_ENDPOINT=databricks-claude-sonnet-4-6

# Classic single-user cluster id for the databricks.yml ingest/client jobs.
# Only needed for bundle runs, not for the read-only local demo.
DATABRICKS_CLUSTER_ID=

NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=

# --- dbxcarta overlay for the Finance Genie Lakehouse ---------------------

DBXCARTA_CATALOG=graph-enriched-lakehouse
DBXCARTA_SCHEMAS=graph-enriched-schema
DATABRICKS_VOLUME_PATH=/Volumes/graph-enriched-lakehouse/graph-enriched-schema/graph-enriched-volume

DBXCARTA_SUMMARY_VOLUME=/Volumes/graph-enriched-lakehouse/graph-enriched-schema/graph-enriched-volume/dbxcarta/runs
DBXCARTA_SUMMARY_TABLE=graph-enriched-lakehouse.graph-enriched-schema.dbxcarta_run_summary

DBXCARTA_INCLUDE_VALUES=true
DBXCARTA_SAMPLE_LIMIT=10
DBXCARTA_SAMPLE_CARDINALITY_THRESHOLD=50

DBXCARTA_INCLUDE_EMBEDDINGS_TABLES=true
DBXCARTA_INCLUDE_EMBEDDINGS_COLUMNS=true
DBXCARTA_INCLUDE_EMBEDDINGS_VALUES=true
DBXCARTA_INCLUDE_EMBEDDINGS_SCHEMAS=true
DBXCARTA_INCLUDE_EMBEDDINGS_DATABASES=true

DBXCARTA_EMBEDDING_ENDPOINT=databricks-gte-large-en
DBXCARTA_EMBEDDING_DIMENSION=1024

DBXCARTA_CLIENT_QUESTIONS=/Volumes/graph-enriched-lakehouse/graph-enriched-schema/graph-enriched-volume/dbxcarta/questions.json
DBXCARTA_CLIENT_ARMS=no_context,schema_dump,graph_rag
DBXCARTA_INJECT_CRITERIA=false
