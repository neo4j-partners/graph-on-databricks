# dbxcarta CLI overlay for the Finance Genie Lakehouse.
#
# Select it for any dbxcarta CLI command with:
#   uv run dbxcarta preset finance_genie_dbxcarta:preset --check-ready \
#     --env-file finance-genie/dbxcarta/dbxcarta-overlay.env
# or export DBXCARTA_ENV_FILE to the same path.
#
# Overlay-only and secret-free: it carries only dbxcarta-scoped values and is
# layered over the shared base .env (Databricks infra + Neo4j secrets). No
# NEO4J_* or tokens belong here, so this file is committed. This is NOT the
# standalone local-demo config (see ./.env / ./.env.sample).
#
# Catalog scope: the single Finance Genie catalog graph-on-databricks with
# the graph-enriched-schema schema, owned by finance-genie/enrichment-pipeline.
# The same catalog holds the dbxcarta ops volume (graph-enriched-volume), the
# run-summary table, and the uploaded question set, so there is no separate ops
# catalog to bootstrap.

# Per-integration Neo4j secret scope (a scope NAME, not a secret). Overrides the
# base .env default so the ingest reads this integration's own instance. The
# cluster ingest fetches NEO4J_URI/USERNAME/PASSWORD from this scope itself.
DATABRICKS_SECRET_SCOPE=dbxcarta-neo4j-finance-genie

DBXCARTA_CATALOG=graph-on-databricks
DBXCARTA_SCHEMAS=graph-enriched-schema
DATABRICKS_VOLUME_PATH=/Volumes/graph-on-databricks/graph-enriched-schema/graph-enriched-volume

DBXCARTA_SUMMARY_VOLUME=/Volumes/graph-on-databricks/graph-enriched-schema/graph-enriched-volume/dbxcarta/runs
DBXCARTA_SUMMARY_TABLE=graph-on-databricks.graph-enriched-schema.dbxcarta_run_summary

DBXCARTA_INCLUDE_VALUES=true
DBXCARTA_SAMPLE_LIMIT=10
DBXCARTA_SAMPLE_CARDINALITY_THRESHOLD=50

DBXCARTA_INCLUDE_EMBEDDINGS_TABLES=true
DBXCARTA_INCLUDE_EMBEDDINGS_COLUMNS=true
DBXCARTA_INCLUDE_EMBEDDINGS_VALUES=true
DBXCARTA_INCLUDE_EMBEDDINGS_SCHEMAS=true
DBXCARTA_INCLUDE_EMBEDDINGS_DATABASES=true

DBXCARTA_EMBEDDING_ENDPOINT=databricks-gte-large-en
DBXCARTA_EMBEDDING_DIMENSION=1024

# Model Serving endpoint the client evaluation calls to generate SQL. Ingest
# ignores it; it is forwarded to both jobs and only the client reads it.
DBXCARTA_CHAT_ENDPOINT=databricks-claude-sonnet-4-6

DBXCARTA_CLIENT_QUESTIONS=/Volumes/graph-on-databricks/graph-enriched-schema/graph-enriched-volume/dbxcarta/questions.json
DBXCARTA_CLIENT_ARMS=no_context,schema_dump,graph_rag
DBXCARTA_SCHEMA_DUMP_MAX_CHARS=50000
DBXCARTA_INJECT_CRITERIA=false
DBXCARTA_CLIENT_MAX_EXPANSION_TABLES=20
