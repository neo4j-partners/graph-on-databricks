# Copy to .env and fill in. The loader WIPES the target database on every
# run, so point it at a database dedicated to this demo.

# --- Neo4j (load.py, gds.py) ---
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# --- Databricks / Unity Catalog (upload.py, guard.py) ---
# Auth: either a CLI profile (DATABRICKS_CONFIG_PROFILE) or host + token.
DATABRICKS_CONFIG_PROFILE=
DATABRICKS_HOST=https://xxxxxxxx.cloud.databricks.com
DATABRICKS_TOKEN=
# SQL warehouse that runs the CREATE TABLE statements.
DATABRICKS_WAREHOUSE_ID=
# Target catalog.schema.volume. DataSource.table values in data_sources.csv
# are schema-qualified (supplier_risk.<table>), so keep UC_SCHEMA=supplier_risk.
UC_CATALOG=graph-on-databricks
UC_SCHEMA=supplier_risk
UC_VOLUME=supplier_risk_files

# --- Genie space (guard.py) ---
# The Story 1 space the vocabulary guard scans. guard.py defaults to the
# standing space, so this only needs setting to point at a different one.
GENIE_SPACE_ID=
